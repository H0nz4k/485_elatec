  (text "TWN4 carrier Rev B - concrete KiCad symbols and named nets" (at 12.7 10.16 0) (effects (font (size 2.2 2.2))) (uuid "e3f6c7a4-0454-4067-b9f4-c6aafb794082"))
  (text "Reader carrier: 12-48V input, protected 5V rail, RS-485/OSDP, relay contact, powered lock output, door inputs" (at 12.7 15.24 0) (effects (font (size 1.2 1.2))) (uuid "68d1d3a2-c9da-46c6-9b9b-6bcf810470f2"))
  (text "RPi gateway/HAT: hardware UART + RS-485 bus port; keep galvanic isolation as Rev C option after field requirements are known" (at 12.7 477.52 0) (effects (font (size 1.2 1.2))) (uuid "8026615b-8531-4329-af70-1a2808be1ec2"))
  (text "CHECK BEFORE PCB: TWN4 COM1 TX/RX are documented as low-active TTL; verify polarity/inversion on scope with current firmware." (at 12.7 373.38 0) (effects (font (size 1.2 1.2))) (uuid "663ea3b8-d7e9-41d4-b3cd-b1bbae43a1d0"))
  (text "BLE note: TWN4 BLE module keeps COM2/GPIO7 reserved; this carrier leaves BLE path inside reader untouched." (at 12.7 386.08 0) (effects (font (size 1.2 1.2))) (uuid "571b687d-d4b7-472d-804f-5d999ed506c7"))
  (text "Power values: F1 1.5A 60V+ fuse/PTC; add TVS after exact cable/PoE surge target is chosen." (at 12.7 393.7 0) (effects (font (size 1.05 1.05))) (uuid "078f1a43-ee77-4e80-8ac6-95221df16624"))
  (text "LM5164 values: Target 5V: L1 47uH shielded, RON about 200k, FB divider 604k/100k, CIN/COUT X7R ceramics." (at 12.7 400.05 0) (effects (font (size 1.05 1.05))) (uuid "a310f68e-e18a-4459-a95f-9352f53c6ba7"))
  (text "RS-485 bus: THVD1450 at 5V on reader, 3.3V on RPi; add 120R termination by jumper and 680R bias option on one bus end." (at 12.7 406.4 0) (effects (font (size 1.05 1.05))) (uuid "3993bed2-8ea4-40e8-b1f6-e188d296f573"))
  (text "Inputs: DOOR/REX/TAMPER/AUX use MCP23008; final Rev C should add RC + ESD + pull topology per cable length." (at 12.7 412.75 0) (effects (font (size 1.05 1.05))) (uuid "d8849280-1e9a-4d08-91eb-f471e8447dfb"))
  (text "Lock output: Low-side FET drives lock/sounder from VIN_PROT; use flyback diode/TVS sized for selected strike or maglock." (at 12.7 419.1 0) (effects (font (size 1.05 1.05))) (uuid "7fc96c86-181a-4848-a957-7a1b44496b55"))
